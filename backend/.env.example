# Port the server will run on (Default: 5000)
PORT=5000

# MongoDB URI connection string
# Local: mongodb://127.0.0.1:27017/mindspark
# Production: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mindspark?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/mindspark

# JWT Authentication Config
JWT_SECRET=your_jwt_strong_secret_key_here
JWT_EXPIRES_IN=7d

# Razorpay Payment Gateway (Test or Live keys)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# Frontend Application URL (For CORS validation)
# Local: http://localhost:3000
# Production: https://your-domain-or-vercel-app.vercel.app
CLIENT_URL=http://localhost:3000

# Platform commission rate (e.g. 0.20 = 20%)
PLATFORM_COMMISSION=0.20
